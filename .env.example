# AgentSurfer — local dev / E2E secrets.
# Copy to .env (which is gitignored) and fill in. Never commit .env.

# Used by `bun run e2e:live` and ad-hoc scripts that hit the live provider.
# Get one at https://platform.minimaxi.com/user-center/basic-information/keys
MINIMAX_API_KEY=

# Used for the MiMo live request test (Task #20). Get one at
# https://platform.xiaomimimo.com/user-center/api-keys
MIMO_API_KEY=

# Used for the StepFun (阶跃星辰) live request test
# (`bun run scripts/test-stepfun.ts`) and the @live E2E specs.
# Get one at https://platform.stepfun.com/user-center/basic-information/keys
# Endpoint: https://api.stepfun.com/step_plan/v1  (Step Plan channel)
# Model:    step-3.7-flash
STEPFUN_API_KEY=

# Optional: override the mock LLM base URL during dev.
# MOCK_LLM_URL=http://localhost:9876/v1
